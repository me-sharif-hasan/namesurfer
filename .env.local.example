# ══════════════════════════════════════════════════════════════════
# Firebase Client Configuration (Browser)
# Get from: Firebase Console > Project Settings > General
# ══════════════════════════════════════════════════════════════════
NEXT_PUBLIC_FIREBASE_API_KEY=AIza...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abc123

# ══════════════════════════════════════════════════════════════════
# Firebase Admin SDK (Server-side ONLY)
# OPTION 1: Place firebase-admin-key.json in project root (recommended)
# OPTION 2: Uncomment and fill the three lines below
# ══════════════════════════════════════════════════════════════════
# FIREBASE_ADMIN_PROJECT_ID=your-project-id
# FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
# FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Firebase Realtime Database (for onboarding job queue + real-time SSE)
# Enable RTDB in Firebase Console, then copy the URL here
FIREBASE_DATABASE_URL=https://your-project-default-rtdb.asia-southeast1.firebasedatabase.app

# ══════════════════════════════════════════════════════════════════
# PowerDNS Configuration (Server-side ONLY)
# ══════════════════════════════════════════════════════════════════
POWERDNS_API_URL=http://YOUR_PDNS_IP:8081
POWERDNS_API_KEY=samsu-dns
POWERDNS_ZONE=inthespace.online.
DEFAULT_DNS_TARGET_IP=104.0.1.112

# Application
NEXT_PUBLIC_PARENT_DOMAIN=inthespace.online

# Subdomain limit per user (admin has unlimited)
MAX_SUBDOMAINS_PER_USER=10

# ══════════════════════════════════════════════════════════════════
# Onboarding Worker Configuration
# ══════════════════════════════════════════════════════════════════

# Max simultaneous provisioning jobs (queues the rest)
MAX_CONCURRENT_ONBOARDING=3

# Per-user resource quotas
USER_STORAGE_QUOTA_MB=500
USER_RAM_QUOTA_MB=200

# ══════════════════════════════════════════════════════════════════
# MySQL / MariaDB (Server-side, used by worker.js via provision.sh)
# ══════════════════════════════════════════════════════════════════
MYSQL_HOST=localhost
MYSQL_ROOT_USER=root
MYSQL_ROOT_PASSWORD=your_mysql_root_password

# ══════════════════════════════════════════════════════════════════
# Email / SMTP (for OTP delivery)
# See HOSTING_SETUP.md § 7 for Gmail App Password setup
# ══════════════════════════════════════════════════════════════════
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="InTheSpace Hosting <noreply@inthespace.online>"

# OTP expiry in minutes (default 15)
OTP_EXPIRY_MINUTES=15
